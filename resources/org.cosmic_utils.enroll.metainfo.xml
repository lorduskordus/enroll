<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
  <id>org.cosmic_utils.enroll</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <name>Enroll</name>
  <summary>Fingerprint record management</summary>
  <summary xml:lang="cs">GUI vytvořené pomocí toolkitu COSMIC pro registraci otisků prstů pomocí fprintd</summary>
  <summary xml:lang="fi">Sormenjälkien hallinointi</summary>
  <developer id="org.cosmic-utils">
    <name>Joonas Tuomi</name>
  </developer>
  <description>
    <p>
      Fingerprint management for single and multi-user systems. Allows you to register, verify and delete prints.
    </p>
    <p xml:lang="cs">
      Správa otisků prstů pro víceuživatelské systémy pomocí služby fprintd. Umožňuje registrovat a mazat otisky prstů pro ověřování ve vašem systému Linux.
    </p>
    <p xml:lang="fi">
      Sormenjälkien hallinnointi yhden ja useamman käyttäjän järjestelmille. Sallii sinun luoda, varmentaa sekä poistaa jälkiä.
     </p>
  </description>
  <icon type="remote" width="64" height="64" scale="1">
    https://github.com/cosmic-utils/enroll/raw/main/resources/icons/hicolor/scalable/apps/enroll.svg
  </icon>
  <launchable type="desktop-id">org.cosmic_utils.enroll.desktop</launchable>
  <provides>
      <binary>cosmic-utils-enroll</binary>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <categories>
    <category>Utility</category>
    <category>System</category>
    <category>X-COSMIC</category>
  </categories>
  <keywords>
    <keyword>Fingerprint</keyword>
    <keyword>Authentication</keyword>
    <keyword>COSMIC</keyword>
    <keyword xml:lang="cs">Otisky prstů</keyword>
    <keyword xml:lang="cs">Ověřování</keyword>
    <keyword xml:lang="cs">COSMIC</keyword>
    <keyword xml:lang="fi">Sormenjälki</keyword>
    <keyword xml:lang="fi">Tunnistautuminen</keyword>
    <keyword xml:lang="fi">COSMIC</keyword>
  </keywords>
  <branding>
